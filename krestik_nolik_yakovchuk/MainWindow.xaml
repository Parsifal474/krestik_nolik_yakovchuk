<Window x:Class="krestik_nolik_yakovchuk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Крестики-Нолики by рыжик"
        Height="650" Width="700"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <Border Grid.Column="0" Background="#2D2D44" Margin="0,0,10,0">
            <StackPanel Margin="15">

                <!-- Заголовок -->
                <TextBlock Text="КРЕСТИКИ-НОЛИКИ"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#FF6B6B"
                   TextAlignment="Center"
                   Margin="0,0,0,30"
                   TextWrapping="Wrap"/>

                <!-- Выбор режима -->
                <TextBlock Text="🎮 Режим игры:"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#A0A0A0"
                   Margin="0,0,0,10"/>

                <Button Content="🤖 Против компьютера"
                Click="PlayWithAI_Click"
                Padding="12,12"
                FontSize="12"
                Margin="0,0,0,8"
                Background="#4ECDC4"
                Foreground="White"
                Cursor="Hand"
                BorderThickness="0"
                FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45B7B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="👥 Два игрока"
                Click="PlayWithPlayer_Click"
                Padding="12,12"
                FontSize="12"
                Margin="0,0,0,20"
                Background="#95E1D3"
                Foreground="#2D2D44"
                Cursor="Hand"
                BorderThickness="0"
                FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7FD1C3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- СЧЁТ -->
                <Border Background="#3D3D5C" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 СЧЁТ"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FFD93D"
                           TextAlignment="Center"
                           Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Игрок ❌"
                                   FontSize="10"
                                   Foreground="#FF6B6B"
                                   TextAlignment="Center"/>
                                <TextBlock x:Name="ScoreX"
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF6B6B"
                                   TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Ничьи"
                                   FontSize="10"
                                   Foreground="#A0A0A0"
                                   TextAlignment="Center"/>
                                <TextBlock x:Name="ScoreDraw"
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#A0A0A0"
                                   TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Игрок ⭕"
                                   FontSize="10"
                                   Foreground="#4ECDC4"
                                   TextAlignment="Center"/>
                                <TextBlock x:Name="ScoreO"
                                   Text="0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#4ECDC4"
                                   TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Статус -->
                <TextBlock Text="📌 Статус:"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#A0A0A0"
                   Margin="0,0,0,8"/>

                <Border Background="#3D3D5C" CornerRadius="8" Padding="10">
                    <TextBlock x:Name="GameStatus"
                       Text="Выберите режим игры"
                       FontSize="12"
                       Foreground="#FFD93D"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"/>
                </Border>

                <!-- Кнопки управления -->
                <Button Content="🔄 Новая игра"
                Click="RestartGame_Click"
                Padding="12,12"
                FontSize="12"
                Margin="0,15,0,8"
                Background="#FF6B6B"
                Foreground="White"
                Cursor="Hand"
                BorderThickness="0"
                FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EE5A5A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="🗑️ Сбросить счёт"
                Click="ResetScore_Click"
                Padding="12,12"
                FontSize="12"
                Margin="0,0,0,8"
                Background="#6C757D"
                Foreground="White"
                Cursor="Hand"
                BorderThickness="0"
                FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#5A6268"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Кнопка кастомизации -->
                <Button Content="🎨 Кастомизация"
                Click="OpenCustomization_Click"
                Padding="12,12"
                FontSize="12"
                Margin="0,0,0,8"
                Background="#9D4EDD"
                Foreground="White"
                Cursor="Hand"
                BorderThickness="0"
                FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#8A3FC9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- ЛИЧНАЯ ПОДПИСЬ -->
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="by рыжик"
                       FontSize="11"
                       Foreground="#6C757D"
                       TextAlignment="Center"
                       FontStyle="Italic"
                       Opacity="1"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ИГРОВОЕ ПОЛЕ -->
        <Grid Grid.Column="1" Background="#1E1E2E">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- Текущий ход -->
                <Border x:Name="TurnIndicator"
                        Background="#2D2D44"
                        CornerRadius="15"
                        Padding="25,15"
                        Margin="0,0,0,30"
                        Visibility="Visible">
                    <TextBlock x:Name="GameStatusCenter"
                               Text="Ход игрока: ❌"
                               FontSize="24"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Foreground="#FFD93D"/>
                </Border>

                <!-- Игровое поле -->
                <Border Background="#2D2D44"
                        CornerRadius="15"
                        Padding="15"
                        BorderBrush="#3D3D5C"
                        BorderThickness="2">
                    <Grid x:Name="GameBoard" Width="350" Height="350">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="Btn0" Grid.Row="0" Grid.Column="0" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn1" Grid.Row="0" Grid.Column="1" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn2" Grid.Row="0" Grid.Column="2" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn3" Grid.Row="1" Grid.Column="0" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn4" Grid.Row="1" Grid.Column="1" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn5" Grid.Row="1" Grid.Column="2" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn6" Grid.Row="2" Grid.Column="0" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn7" Grid.Row="2" Grid.Column="1" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="Btn8" Grid.Row="2" Grid.Column="2" Click="Cell_Click"
                                FontSize="48" FontWeight="Bold" 
                                Background="#3D3D5C" Foreground="White"
                                BorderBrush="#4D4D6C" BorderThickness="1"
                                Cursor="Hand" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4D4D6C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>