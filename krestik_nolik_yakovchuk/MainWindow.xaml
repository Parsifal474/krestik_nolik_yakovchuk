<Window x:Class="krestik_nolik_yakovchuk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Яковчук Василий ИСП(11)-24-2 by рыжик"
        Height="600" Width="600"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        Foreground="Black">

    <!-- Основная сетка окна -->
    <Grid>
        <!-- Определяем две колонки: левая для меню, правая для игры -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== ЛЕВАЯ ПАНЕЛЬ (МЕНЮ) ==================== -->
        <StackPanel Grid.Column="0"
                    Background="#2C3E50"
                    Margin="15,20,15,20"
                    VerticalAlignment="Stretch">

            <!-- Заголовок -->
            <TextBlock Text="КРЕСТИКИ-НОЛИКИ"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,30"
                       TextWrapping="Wrap"/>

            <!-- === ВЫБОР РЕЖИМА === -->
            <TextBlock Text="Выбор режима:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#ECF0F1"
                       Margin="0,0,0,10"/>

            <Button Content="👤 Против ПК"
                    Click="PlayWithAI_Click"
                    Padding="12,10"
                    FontSize="11"
                    Margin="0,0,0,8"
                    Background="#3498DB"
                    Foreground="White"
                    Cursor="Hand"
                    BorderThickness="0"
                    FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="👥 Два игрока"
                    Click="PlayWithPlayer_Click"
                    Padding="12,10"
                    FontSize="11"
                    Margin="0,0,0,20"
                    Background="#27AE60"
                    Foreground="White"
                    Cursor="Hand"
                    BorderThickness="0"
                    FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E8449"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- === ЛИНИЯ РАЗДЕЛЕНИЯ === -->
            <Separator Background="#34495E" Height="1" Margin="0,0,0,20"/>

            <!-- === СТАТУС ИГРЫ === -->
            <TextBlock Text="Статус:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#ECF0F1"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="GameStatus"
                       Text="Выберите режим"
                       FontSize="11"
                       Foreground="#F39C12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       FontWeight="Bold"/>

            <!-- === КНОПКА НОВОЙ ИГРЫ === -->
            <Button Content="🔄 Новая игра"
                    Click="RestartGame_Click"
                    Padding="12,12"
                    FontSize="12"
                    Background="#E74C3C"
                    Foreground="White"
                    Cursor="Hand"
                    BorderThickness="0"
                    FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- === ЗАПОЛНИТЕЛЬ === -->
            <TextBlock Margin="0,40,0,0"/>
        </StackPanel>

        <!-- ==================== ПРАВАЯ ПАНЕЛЬ (ИГРОВОЕ ПОЛЕ) ==================== -->
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <!-- Информация о ходе (спрятана до выбора режима) -->
            <StackPanel x:Name="GameInfo"
                        Visibility="Visible">

                <!-- Текст текущего состояния -->
                <TextBlock x:Name="GameStatusCenter"
                           Text="Ход игрока X"
                           FontSize="22"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,25"
                           Foreground="#2C3E50"/>

                <!-- Игровое поле 3x3 -->
                <Grid x:Name="GameBoard"
                      Width="300"
                      Height="300"
                      Margin="0,0,0,0">

                    <!-- Колонки -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Строки -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопки ячеек (0–8) -->
                    <!-- Верхний ряд -->
                    <Button x:Name="Btn0" Grid.Row="0" Grid.Column="0" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn1" Grid.Row="0" Grid.Column="1" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn2" Grid.Row="0" Grid.Column="2" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>

                    <!-- Средний ряд -->
                    <Button x:Name="Btn3" Grid.Row="1" Grid.Column="0" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn4" Grid.Row="1" Grid.Column="1" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn5" Grid.Row="1" Grid.Column="2" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>

                    <!-- Нижний ряд -->
                    <Button x:Name="Btn6" Grid.Row="2" Grid.Column="0" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn7" Grid.Row="2" Grid.Column="1" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="Btn8" Grid.Row="2" Grid.Column="2" Click="Cell_Click"
                            FontSize="40" FontWeight="Bold" Background="White" Foreground="#2C3E50"
                            BorderBrush="#BDC3C7" BorderThickness="1" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
