<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="krestik_nolik_yakovchuk.CustomizationWindow"
        Title="🎨 Кастомизация игры by рыжик" 
        Height="550" Width="420"
        Background="#2B2B40"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройка символов" 
                   FontSize="24" FontWeight="Bold" 
                   Foreground="White" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,30"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Настройки для X -->
                <Border Background="#35354A" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Игрок X" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="#FF6B6B" 
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Выберите символ:" 
                                   Foreground="#A0A0A0" 
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="SymbolXCombo" 
                                  SelectionChanged="SymbolXCombo_SelectionChanged"
                                  Background="#3D3D5C" 
                                  Foreground="Black"
                                  Padding="8,5"
                                  BorderThickness="0">
                            <ComboBoxItem Content="❌" IsSelected="True"/>
                            <ComboBoxItem Content="X"/>
                            <ComboBoxItem Content="✖"/>
                            <ComboBoxItem Content="⚔️"/>
                            <ComboBoxItem Content="🔥"/>
                            <ComboBoxItem Content="⭐"/>
                            <ComboBoxItem Content="💥"/>
                        </ComboBox>

                        <TextBlock Text="Выберите цвет:" 
                                   Foreground="#A0A0A0" 
                                   Margin="0,15,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Tag="#FFFF6B6B" Click="ColorButton_Click" 
                                    Background="#FFFF6B6B" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="2" 
                                    BorderBrush="White"/>
                            <Button Tag="#FF4E89FF" Click="ColorButton_Click" 
                                    Background="#FF4E89FF" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FF4ECD88" Click="ColorButton_Click" 
                                    Background="#FF4ECD88" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FFFFD93D" Click="ColorButton_Click" 
                                    Background="#FFFFD93D" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FF9D4EDD" Click="ColorButton_Click" 
                                    Background="#FF9D4EDD" Width="40" Height="40" 
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Настройки для O -->
                <Border Background="#35354A" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Игрок O" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="#4ECDC4" 
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Выберите символ:" 
                                   Foreground="#A0A0A0" 
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="SymbolOCombo" 
                                  SelectionChanged="SymbolOCombo_SelectionChanged"
                                  Background="#3D3D5C" 
                                  Foreground="Black"
                                  Padding="8,5"
                                  BorderThickness="0">
                            <ComboBoxItem Content="⭕" IsSelected="True"/>
                            <ComboBoxItem Content="O"/>
                            <ComboBoxItem Content="●"/>
                            <ComboBoxItem Content="🛡️"/>
                            <ComboBoxItem Content="💧"/>
                            <ComboBoxItem Content="🌙"/>
                            <ComboBoxItem Content="🔷"/>
                        </ComboBox>

                        <TextBlock Text="Выберите цвет:" 
                                   Foreground="#A0A0A0" 
                                   Margin="0,15,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Tag="#FFFF6B6B" Click="ColorButtonO_Click" 
                                    Background="#FFFF6B6B" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FF4E89FF" Click="ColorButtonO_Click" 
                                    Background="#FF4E89FF" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FF4ECD88" Click="ColorButtonO_Click" 
                                    Background="#FF4ECD88" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="2" 
                                    BorderBrush="White"/>
                            <Button Tag="#FFFFD93D" Click="ColorButtonO_Click" 
                                    Background="#FFFFD93D" Width="40" Height="40" 
                                    Margin="0,0,10,0" BorderThickness="0"/>
                            <Button Tag="#FF9D4EDD" Click="ColorButtonO_Click" 
                                    Background="#FF9D4EDD" Width="40" Height="40" 
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" 
                    Click="SaveButton_Click"
                    Padding="20,10"
                    Background="#4ECDC4"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    Margin="0,0,10,0"/>
            <Button Content="❌ Отмена" 
                    Click="CancelButton_Click"
                    Padding="20,10"
                    Background="#6C757D"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>